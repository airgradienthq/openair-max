/**
 * Local diagnostic secrets template. Copy this to `secrets.h` (which is
 * gitignored) and fill in the real values for your bench setup.
 *
 * Used only when AG_DEBUG_UDP_LOG is enabled in MaxConfig.h.
 */

#ifndef MAX_SECRETS_H
#define MAX_SECRETS_H

#define AG_DEBUG_UDP_SSID     "your-ssid"
#define AG_DEBUG_UDP_PASSWORD "your-password"
#define AG_DEBUG_UDP_HOST     "192.168.x.x"
#define AG_DEBUG_UDP_PORT     5514

#endif
